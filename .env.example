# OIDC Authentication (required)
OIDC_ISSUER_URL=https://tai.it.tencent.com/api/auth-center/oauth2/
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_REDIRECT_URL=http://127.0.0.1:8000/auth/callback
OIDC_SCOPES=openid,profile

# Application settings
APP_SECRET_KEY=change-me-to-a-random-string
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (PostgreSQL)
APP_DB_URL=postgresql+asyncpg://postgres:mysecretpassword@localhost:5433/fastapi_demo

# JWT Authentication
APP_JWT_SECRET=change-me-to-a-random-jwt-secret
APP_JWT_EXPIRE_MINUTES=60
